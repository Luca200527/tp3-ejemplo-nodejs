      "item": [
        {
          "name": "Get all alumnos",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/alumnos",
              "host": ["{{base_url}}"],
              "path": ["alumnos"]
            }
          }
        },
        {
          "name": "Get alumno by legajo",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/alumnos/:legajo",
              "host": ["{{base_url}}"],
              "path": ["alumnos", ":legajo"],
              "variable": [
                {
                  "key": "legajo",
                  "value": "10001"
                }
              ]
            }
          }
        },
        {
          "name": "Create alumno",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"legajo\": 12345,\n  \"nombre\": \"NombreEjemplo\",\n  \"apellido\": \"ApellidoEjemplo\",\n  \"email\": \"ejemplo@facultad.edu.ar\",\n  \"fechaAlta\": \"2026-06-01\",\n  \"modificacion\": \"2026-06-01\",\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/alumnos",
              "host": ["{{base_url}}"],
              "path": ["alumnos"]
            }
          }
        },
        {
          "name": "Update alumno",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"NombreModificado\",\n  \"apellido\": \"ApellidoModificado\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/alumnos/:legajo",
              "host": ["{{base_url}}"],
              "path": ["alumnos", ":legajo"],
              "variable": [
                {
                  "key": "legajo",
                  "value": "12345"
                }
              ]
            }
          }
        },
        {
